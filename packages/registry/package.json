{
  "name": "@saferkeys/registry",
  "version": "0.1.0",
  "description": "Community-maintained registry of AI provider API key metadata",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./providers.json": "../../providers.json"
